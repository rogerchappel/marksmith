{
  "name": "marksmith",
  "version": "0.1.0",
  "description": "Local-first deterministic HTML to Markdown converter for docs, prompts, and agent workflows.",
  "type": "module",
  "main": "./src/converter/index.js",
  "exports": {
    ".": "./src/converter/index.js",
    "./cli": "./src/cli/index.js"
  },
  "bin": {
    "marksmith": "./src/cli/index.js"
  },
  "files": [
    "src",
    "README.md",
    "docs",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "check": "node --check src/cli/index.js && node --check src/converter/index.js && node --check src/parser/html.js",
    "test": "node --test",
    "smoke": "bash scripts/smoke.sh",
    "release:check": "npm run check && npm test && npm run smoke && npm pack --dry-run"
  },
  "keywords": [
    "html",
    "markdown",
    "converter",
    "local-first",
    "agent-tools"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/marksmith.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/marksmith/issues"
  },
  "homepage": "https://github.com/rogerchappel/marksmith#readme"
}
